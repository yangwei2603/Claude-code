#!/usr/bin/env bash
# ================================================================
# pre-commit hook — 提交前自动化检查
# 项目: Claude Code  |  仓库: yangwei2603/Claude-code
# ================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

ERRORS=0
WARNINGS=0

echo -e "${CYAN}🔍 [pre-commit] 开始自动化检查...${NC}"

# ----------------------------------------------------------------
# 1. 检查大文件（>5MB）
# ----------------------------------------------------------------
echo -e "${CYAN}[1/4] 检查大文件 (>5MB)...${NC}"
MAX_SIZE=$((5 * 1024 * 1024))  # 5MB in bytes

while IFS= read -r -d '' file; do
  if [ -f "$file" ]; then
    size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
    if [ "$size" -gt "$MAX_SIZE" ]; then
      size_mb=$(echo "scale=1; $size/1048576" | bc)
      echo -e "  ${RED}✗ 大文件: $file (${size_mb}MB)${NC}"
      ERRORS=$((ERRORS + 1))
    fi
  fi
done < <(git diff --cached --name-only -z --diff-filter=ACM)

if [ "$ERRORS" -eq 0 ]; then
  echo -e "  ${GREEN}✓ 无大文件${NC}"
fi

# ----------------------------------------------------------------
# 2. 检查敏感信息（密码/密钥/Token）
# ----------------------------------------------------------------
echo -e "${CYAN}[2/4] 检查敏感信息...${NC}"
SENSITIVE_PATTERNS=(
  'password\s*=\s*["\x27][^"\x27]{6,}'
  'secret\s*=\s*["\x27][^"\x27]{8,}'
  'api_key\s*=\s*["\x27][^"\x27]{8,}'
  'access_token\s*=\s*["\x27][^"\x27]{8,}'
  'private_key\s*=\s*["\x27][^"\x27]{8,}'
  'sk-[a-zA-Z0-9]{20,}'
  'ghp_[a-zA-Z0-9]{36}'
  'AKIA[0-9A-Z]{16}'
  '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'
)

SENSITIVE_FOUND=0
while IFS= read -r -d '' file; do
  # 跳过二进制文件和特定目录
  if [[ "$file" == *.png || "$file" == *.jpg || "$file" == *.gif || \
        "$file" == *.pdf || "$file" == *.zip || "$file" == *.mp4 ]]; then
    continue
  fi
  if [[ "$file" == *"node_modules/"* || "$file" == *".git/"* ]]; then
    continue
  fi
  
  for pattern in "${SENSITIVE_PATTERNS[@]}"; do
    if git diff --cached -- "$file" | grep -qiE "$pattern" 2>/dev/null; then
      echo -e "  ${RED}✗ 疑似敏感信息: $file (匹配: $pattern)${NC}"
      SENSITIVE_FOUND=1
      ERRORS=$((ERRORS + 1))
      break
    fi
  done
done < <(git diff --cached --name-only -z --diff-filter=ACM)

if [ "$SENSITIVE_FOUND" -eq 0 ]; then
  echo -e "  ${GREEN}✓ 未发现敏感信息${NC}"
fi

# ----------------------------------------------------------------
# 3. Python 语法检查
# ----------------------------------------------------------------
echo -e "${CYAN}[3/4] Python 语法检查...${NC}"
PY_ERRORS=0

while IFS= read -r file; do
  if [[ "$file" == *.py ]]; then
    if command -v python3 &>/dev/null; then
      if ! python3 -m py_compile "$file" 2>/tmp/py_error; then
        echo -e "  ${RED}✗ Python 语法错误: $file${NC}"
        cat /tmp/py_error | sed 's/^/    /'
        PY_ERRORS=$((PY_ERRORS + 1))
        ERRORS=$((ERRORS + 1))
      fi
    fi
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "$PY_ERRORS" -eq 0 ]; then
  echo -e "  ${GREEN}✓ Python 语法检查通过${NC}"
fi

# ----------------------------------------------------------------
# 4. JS/TS 语法检查（node --check）
# ----------------------------------------------------------------
echo -e "${CYAN}[4/4] JavaScript 语法检查...${NC}"
JS_ERRORS=0

while IFS= read -r file; do
  if [[ "$file" == *.js || "$file" == *.mjs ]]; then
    if command -v node &>/dev/null; then
      if ! node --check "$file" 2>/tmp/js_error; then
        echo -e "  ${RED}✗ JS 语法错误: $file${NC}"
        cat /tmp/js_error | sed 's/^/    /'
        JS_ERRORS=$((JS_ERRORS + 1))
        ERRORS=$((ERRORS + 1))
      fi
    fi
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "$JS_ERRORS" -eq 0 ]; then
  echo -e "  ${GREEN}✓ JavaScript 语法检查通过${NC}"
fi

# ----------------------------------------------------------------
# 汇总结果
# ----------------------------------------------------------------
echo ""
if [ "$ERRORS" -gt 0 ]; then
  echo -e "${RED}❌ pre-commit 检查失败，发现 $ERRORS 个问题。${NC}"
  echo -e "${YELLOW}   提示: 使用 git commit --no-verify 可跳过检查（不推荐）${NC}"
  exit 1
else
  echo -e "${GREEN}✅ pre-commit 检查全部通过！${NC}"
  exit 0
fi
