{"type":"message","id":"94eab619","parentId":"774b9f98","timestamp":"2026-04-14T13:34:10.506Z","message":{"role":"assistant","content":[{"type":"text","text":"让我继续完成这个脚本并创建更多自动化脚本："},{"type":"toolCall","id":"call_00_Q0xsSpejRFSEVv8gzw1hA1AR","name":"write","arguments":{"path":"C:\\Users\\hytyw\\.openclaw\\workspace-finops\\自动化脚本\\FinOps资源优化脚本.ps1","content":"# FinOps资源优化脚本\n# 版本: 1.0\n# 功能: 自动化资源利用率分析和优化建议\n\n# 配置参数\n$Config = @{\n    Optimization = @{\n        TargetCPUUtilization = 70  # 目标CPU利用率百分比\n        TargetMemoryUtilization = 75  # 目标内存利用率百分比\n        MaxIdleTimeHours = 24  # 最大闲置时间（小时）\n        MinInstanceCount = 2  # 最小实例数（高可用）\n        AutoScalingEnabled = $true\n        ScheduleOptimization = $true\n    }\n    \n    Analysis = @{\n        HistoricalDays = 30  # 历史数据分析天数\n        ForecastDays = 7  # 预测天数\n        Granularity = \"Hourly\"  # 分析粒度\n    }\n    \n    Actions = @{\n        DryRun = $true  # 干运行模式，不实际执行操作\n        ApprovalRequired = $true  # 需要人工批准\n        NotificationEnabled = $true\n    }\n}\n\n# 主函数\nfunction Start-ResourceOptimization {\n    param(\n        [string]$ResourceType = \"All\",\n        [switch]$ForceAnalysis = $false\n    )\n    \n    Write-Host \"开始资源优化分析\" -ForegroundColor Cyan\n    Write-Host \"资源类型: $ResourceType\" -ForegroundColor Cyan\n    Write-Host \"干运行模式: $($Config.Actions.DryRun)\" -ForegroundColor Yellow\n    \n    try {\n        # 1. 收集资源使用数据\n        $ResourceData = Collect-ResourceData -ResourceType $ResourceType\n        \n        # 2. 分析资源利用率\n        $UtilizationAnalysis = Analyze-ResourceUtilization -ResourceData $ResourceData\n        \n        # 3. 识别优化机会\n        $OptimizationOpportunities = Identify-OptimizationOpportunities -ResourceData $ResourceData -Analysis $UtilizationAnalysis\n        \n        # 4. 生成优化计划\n        $OptimizationPlan = Generate-OptimizationPlan -Opportunities $OptimizationOpportunities\n        \n        # 5. 执行优化操作（如果不在干运行模式）\n        if (-not $Config.Actions.DryRun) {\n            $ExecutionResults = Execute-OptimizationPlan -Plan $OptimizationPlan\n        } else {\n            Write-Host \"干运行模式：跳过实际执行\" -ForegroundColor Yellow\n            $ExecutionResults = @{\n                Status = \"DryRun\"\n                Message = \"优化操作在干运行模式下跳过\"\n                PlannedActions = $OptimizationPlan.Actions.Count\n            }\n        }\n        \n        # 6. 生成优化报告\n        $Report = Generate-OptimizationReport -ResourceData $ResourceData -Analysis $UtilizationAnalysis -Opportunities $OptimizationOpportunities -Plan $OptimizationPlan -Results $ExecutionResults\n        \n        Write-Host \"资源优化分析完成\" -ForegroundColor Green\n        return $Report\n        \n    } catch {\n        Write-Host \"资源优化分析失败: $_\" -ForegroundColor Red\n        throw\n    }\n}\n\n# 资源数据收集函数\nfunction Collect-ResourceData {\n    param([string]$ResourceType)\n    \n    Write-Host \"收集资源使用数据...\" -ForegroundColor Cyan\n    \n    # 模拟资源数据\n    $ResourceData = @{\n        Timestamp = Get-Date\n        ResourceType = $ResourceType\n        Resources = @()\n    }\n    \n    # 模拟虚拟机数据\n    if ($ResourceType -eq \"All\" -or $ResourceType -eq \"VirtualMachines\") {\n        1..10 | ForEach-Object {\n            $ResourceData.Resources += @{\n                Type = \"VirtualMachine\"\n                Id = \"vm-$_\"\n                Name = \"VM-Prod-$_\"\n                Status = \"Running\"\n                Size = if ($_ % 3 -eq 0) { \"Standard_D4s_v3\" } elseif ($_ % 3 -eq 1) { \"Standard_D2s_v3\" } else { \"Standard_D8s_v3\" }\n                CostPerHour = if ($_ % 3 -eq 0) { 0.192 } elseif ($_ % 3 -eq 1) { 0.096 } else { 0.384 }\n                Metrics = @{\n                    CPU = @{\n                        Average = (30, 45, 60, 75, 20, 85)[$_ % 6]\n                        Peak = (60, 70, 85, 95, 40, 98)[$_ % 6]\n                        Trend = \"Stable\"\n                    }\n                    Memory = @{\n                        Average = (40, 55, 65, 80, 25, 90)[$_ % 6]\n                        Peak = (65, 75, 85, 98, 45, 99)[$_ % 6]\n                        Trend = \"Stable\"\n                    }\n                    Network = @{\n                        AverageMBps = (5, 10, 15, 20, 2, 25)[$_ % 6]\n                        PeakMBps = (15, 25, 35, 45, 5, 50)[$_ % 6]\n                    }\n                }\n                Tags = @{\n                    Environment = if ($_ -le 5) { \"Production\" } else { \"Development\" }\n                    Owner = \"Team-$(($_ % 3) + 1)\"\n                    Criticality = if ($_ -le 3) { \"High\" } elseif ($_ -le 7) { \"Medium\" } else { \"Low\" }\n                }\n                UptimeHours = $_ * 24  # 模拟运行时间\n                LastActivity = (Get-Date).AddHours(-($_ * 2))  # 模拟最后活动时间\n            }\n        }\n    }\n    \n    # 模拟数据库实例\n    if ($ResourceType -eq \"All\" -or $ResourceType -eq \"Databases\") {\n        1..5 | ForEach-Object {\n            $ResourceData.Resources += @{\n                Type = \"Database\"\n                Id = \"db-$_\"\n                Name = \"SQL-DB-$_\"\n                Status = \"Online\"\n                Tier = if ($_ % 2 -eq 0) { \"BusinessCritical\" } else { \"GeneralPurpose\" }\n                SizeGB = (100, 250, 500, 1000, 2000)[$_ - 1]\n                CostPerHour = (0.5, 1.2, 2.5, 4.8, 9.6)[$_ - 1]\n                Metrics = @{\n                    DTU = @{\n                        Average = (25, 40, 60, 75, 85)[$_ - 1]\n                        Peak = (45, 65, 85, 95, 98)[$_ - 1]\n                    }\n                    Storage = @{\n                        UsedGB = (30, 120, 280, 650, 1500)[$_ - 1]\n                        Utilization = (30, 48, 56, 65, 75)[$_ - 1]\n                    }\n                }\n                Tags = @{\n                    Environment = if ($_ -le 2) { \"Production\" } else { \"Development\" }\n                    DataClassification = if ($_ -le 2) { \"Sensitive\" } else { \"General\" }\n                }\n            }\n        }\n    }\n    \n    # 模拟存储账户\n    if ($ResourceType -eq \"All\" -or $ResourceType -eq \"Storage\") {\n        1..8 | ForEach-Object {\n            $ResourceData.Resources += @{\n                Type = \"Storage\"\n                Id = \"stor-$_\"\n                Name = \"StorageAcct-$_\"\n                Status = \"Active\"\n                Tier = if ($_ % 3 -eq 0) { \"Hot\" } elseif ($_ % 3 -eq 1) { \"Cool\" } else { \"Archive\" }\n                TotalGB = (1000, 2000, 5000, 10000, 20000, 50000, 100000, 200000)[$_ - 1]\n                UsedGB = (200, 800, 1500, 3500, 8000, 12000, 25000, 50000)[$_ - 1]\n                CostPerMonth = (45, 90, 225, 450, 900, 2250, 4500, 9000)[$_ - 1]\n                AccessPattern = if ($_ -le 3) { \"Frequent\" } elseif ($_ -le 6) { \"Infrequent\" } else { \"Rare\" }\n                LastAccessDays = (1, 3, 7, 30, 60, 90, 180, 365)[$_ - 1]\n            }\n        }\n    }\n    \n    Write-Host \"收集到 $($ResourceData.Resources.Count) 个资源\" -ForegroundColor Green\n    return $ResourceData\n}\n\n# 资源利用率分析函数\nfunction Analyze-ResourceUtilization {\n    param([object]$ResourceData)\n    \n    Write-Host \"分析资源利用率...\" -ForegroundColor Cyan\n    \n    $Analysis = @{\n        Timestamp = Get-Date\n        Summary = @{}\n        ByType = @{}\n        ByEnvironment = @{}\n        Recommendations = @()\n    }\n    \n    # 按类型分组\n    $ByType = $ResourceData.Resources | Group-Object Type\n    \n    foreach ($TypeGroup in $ByType) {\n        $TypeAnalysis = @{\n            Count = $TypeGroup.Count\n            TotalCost = ($TypeGroup.Group | Measure-Object -Property CostPerHour -Sum).Sum * 24 * 30  # 估算月成本\n            UtilizationMetrics = @{}\n            Issues = @()\n        }\n        \n        # 计算利用率指标\n        switch ($TypeGroup.Name) {\n            \"VirtualMachine\" {\n                $AvgCPU = ($TypeGroup.Group.Metrics.CPU.Average | Measure-Object -Average).Average\n                $AvgMemory = ($TypeGroup.Group.Metrics.Memory.Average | Measure-Object -Average).Average\n                \n                $TypeAnalysis.UtilizationMetrics.CPU = $AvgCPU\n                $TypeAnalysis.UtilizationMetrics.Memory = $AvgMemory\n                \n                # 识别低利用率实例\n                $LowUtilization = $TypeGroup.Group | Where-Object { \n                    $_.Metrics.CPU.Average -lt 20 -and $_.Metrics.Memory.Average -lt 25 \n                }\n                \n                if ($LowUtilization.Count -gt 0) {\n                    $TypeAnalysis.Issues += @{\n                        Type = \"LowUtilization\"\n                        Count = $LowUtilization.Count\n                        Resources = $LowUtilization.Name\n                        Recommendation = \"考虑降级实例规格或合并工作负载\"\n                    }\n                }\n            }\n            \n            \"Database\" {\n                $AvgDTU = ($TypeGroup.Group.Metrics.DTU.Average | Measure-Object -Average).Average\n                $AvgStorageUtil = ($TypeGroup.Group.Metrics.Storage.Utilization | Measure-Object -Average).Average\n                \n                $TypeAnalysis.UtilizationMetrics.DTU = $AvgDTU\n                $TypeAnalysis.UtilizationMetrics.Storage = $AvgStorageUtil\n                \n                # 识别过度配置的数据库\n                $OverProvisioned = $TypeGroup.Group | Where-Object { \n                    $_.Metrics.DTU.Average -lt 30 -and $_.SizeGB -gt 500 \n                }\n                \n                if ($OverProvisioned.Count -gt 0) {\n                    $TypeAnalysis.Issues += @{\n                        Type = \"OverProvisioned\"\n                        Count = $OverProvisioned.Count\n                        Resources = $OverProvisioned.Name\n                        Recommendation = \"考虑降级服务层级或调整大小\"\n                    }\n                }\n            }\n            \n            \"Storage\" {\n                $AvgUtilization = ($TypeGroup.Group | ForEach-Object { ($_.UsedGB / $_.TotalGB) * 100 } | Measure-Object -Average).Average\n                $TypeAnalysis.UtilizationMetrics.Storage = $AvgUtilization\n                \n                # 识别冷数据\n                $ColdStorage = $TypeGroup.Group | Where-Object { \n                    $_.AccessPattern -eq \"Rare\" -and $_.Tier -ne \"Archive\" \n                }\n                \n                if ($ColdStorage.Count -gt 0) {\n                    $TypeAnalysis.Issues += @{\n                        Type = \"ColdData\"\n                        Count = $ColdStorage.Count\n                        Resources = $ColdStorage.Name\n                        Recommendation = \"考虑移动到归档存储层\"\n                    }\n                }\n            }\n        }\n        \n        $Analysis.ByType[$TypeGroup.Name] = $TypeAnalysis\n    }\n    \n    # 按环境分组\n    $ByEnvironment = $ResourceData.Resources | Where-Object { $_.Tags.Environment } | Group-Object { $_.Tags.Environment }\n    \n    foreach ($EnvGroup in $ByEnvironment) {\n        $EnvAnalysis = @{\n            Count = $EnvGroup.Count\n            TotalCost = ($EnvGroup.Group | Measure-Object -Property CostPerHour -Sum).Sum * 24 * 30\n            AvgUtilization = @{}\n        }\n        \n        $Analysis.ByEnvironment[$EnvGroup.Name] = $EnvAnalysis\n    }\n    \n    # 计算总体指标\n    $Analysis.Summary.TotalResources = $ResourceData.Resources.Count\n    $Analysis.Summary.EstimatedMonthlyCost = ($ResourceData.Resources | Measure-Object -Property CostPerHour -Sum).Sum * 24 * 30\n    $Analysis.Summary.IssueCount = ($Analysis.ByType.Values.Issues | Measure-Object).Count\n    \n    Write-Host \"资源利用率分析完成\" -ForegroundColor Green\n    return $Analysis\n}\n\n# 优化机会识别函数\nfunction Identify-OptimizationOpportunities {\n    param(\n        [object]$ResourceData,\n        [object]$Analysis\n    )\n    \n    Write-Host \"识别优化机会...\" -ForegroundColor Cyan\n    \n    $Opportunities = @()\n    \n    # 分析虚拟机优化机会\n    $VMs = $ResourceData.Resources | Where-Object { $_.Type -eq \"VirtualMachine\" }\n    \n    foreach ($VM in $VMs) {\n        $VMOpportunities = @()\n        \n        # 1. 检查CPU利用率\n        if ($VM.Metrics.CPU.Average -lt 20) {\n            $VMOpportunities += @{\n                Type = \"RightSize\"\n                Description = \"CPU利用率低 ($($VM.Metrics.CPU.Average)%)\"\n                CurrentSize = $VM.Size\n                RecommendedSize = Get-RecommendedVMSize -CurrentSize $VM.Size -Utilization $VM.Metrics.CPU.Average\n                EstimatedSavings = Calculate-VMSizeSavings -CurrentSize $VM.Size -RecommendedSize $RecommendedSize\n                Impact = \"Low\"\n                Effort = \"Medium\"\n            }\n        }\n        \n        # 2. 检查内存利用率\n        if ($VM.Metrics.Memory.Average -lt 25) {\n            $VMOpportunities += @{\n                Type = \"MemoryOptimization\"\n                Description = \"内存利用率低 ($($VM.Metrics.Memory.Average)%)\"\n                Recommendation = \"考虑减少内存配置\"\n                EstimatedSavings = $VM.CostPerHour * 0.2 * 24 * 30  # 假设节约20%\n                Impact = \"Low\"\n                Effort = \"Medium\"\n            }\n        }\n        \n        # 3. 检查闲置实例\n        $IdleHours = ((Get-Date) - $VM.LastActivity).TotalHours\n        if ($IdleHours -gt $Config.Optimization.MaxIdleTimeHours) {\n            $VMOpportunities += @{\n                Type = \"IdleResource\"\n                Description = \"实例闲置超过 $IdleHours 小时\"\n                Recommendation = \"考虑停止或删除实例\"\n                EstimatedSavings = $VM.CostPerHour * 24 * 30  # 完整月成本\n                Impact = \"High\"\n                Effort = \"Low\"\n            }\n        }\n        \n        # 4. 检查开发环境非工作时间\n        if ($VM.Tags.Environment -eq \"Development\" -and $VM.Status -eq \"Running\") {\n            $VMOpportunities += @{\n                Type = \"ScheduleOptimization\"\n                Description = \"开发环境实例可安排关机时间\"\n                Recommendation = \"配置非工作时间自动关机\"\n                EstimatedSavings = $VM.CostPerHour * 12 * 20  # 假设每天关机12小时，每月20个工作日\n                Impact = \"Medium\"\n                Effort = \"Low\"\n            }\n        }\n        \n        if ($VMOpportunities.Count -gt 0) {\n            $Opportunities += @{\n                ResourceId = $VM.Id\n                ResourceName = $VM.Name\n                ResourceType = $VM.Type\n                Opportunities = $VMOpportunities\n                TotalSavings = ($VMOpportunities.EstimatedSavings | Measure-Object -Sum).Sum\n            }\n        }\n    }\n    \n    # 分析存储优化机会\n    $StorageAccounts = $ResourceData.Resources | Where-Object { $_.Type -eq \"Storage\" }\n    \n    foreach ($Storage in $StorageAccounts) {\n        $StorageOpportunities = @()\n        \n        # 1. 检查存储层级优化\n        $CurrentTier = $Storage.Tier\n        $RecommendedTier = Get-RecommendedStorageTier -AccessPattern $Storage.AccessPattern -LastAccessDays $Storage.LastAccessDays\n        \n        if ($CurrentTier -ne $RecommendedTier) {\n            $StorageOpportunities += @{\n                Type = \"StorageTierOptimization\"\n                Description = \"存储层级不匹配访问模式\"\n                CurrentTier = $CurrentTier\n                RecommendedTier = $RecommendedTier\n                EstimatedSavings = Calculate-StorageTierSavings -CurrentTier $CurrentTier -RecommendedTier $RecommendedTier -SizeGB $Storage.UsedGB\n                Impact = \"Medium\"\n                Effort = \"Low\"\n            }\n        }\n        \n        # 2. 检查存储利用率\n        $Utilization = ($Storage.UsedGB / $Storage.TotalGB) * 100\n        if ($Utilization -lt 50) {\n            $StorageOpportunities += @{\n                Type = \"StorageRightSize\"\n                Description = \"存储利用率低 ($($Utilization.ToString('F1'))%)\"\n                Recommendation = \"考虑减少存储容量\"\n                EstimatedSavings = $Storage.CostPerMonth * 0.3  # 假设节约30%\n                Impact = \"Low\"\n"}}],"api":"openai-completions","provider":"cherry-deepseek","model":"deepseek-chat","usage":{"input":75,"output":4112,"cacheRead":68160,"cacheWrite":0,"totalTokens":72347,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1776173506685}}
