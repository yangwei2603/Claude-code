{"type":"message","id":"bb987f6c","parentId":"7717e352","timestamp":"2026-04-14T13:31:46.669Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_00_aMYovpao2Ickp9axEwyf3rse","name":"write","arguments":{"path":"C:\\Users\\hytyw\\.openclaw\\workspace-finops\\自动化脚本\\FinOps成本监控脚本.ps1","content":"# FinOps成本监控脚本\n# 版本: 1.0\n# 功能: 自动化成本数据收集、分析和报告\n\n# 配置参数\n$Config = @{\n    # 数据源配置\n    DataSources = @{\n        CloudProvider = \"Azure\"  # 可选: Azure, AWS, GCP, AlibabaCloud\n        BillingAPI = $true\n        UsageAPI = $true\n        CostManagementAPI = $true\n    }\n    \n    # 监控配置\n    Monitoring = @{\n        Frequency = \"Daily\"  # Daily, Weekly, Monthly\n        AlertThreshold = 10  # 成本变化超过10%触发警报\n        BudgetThreshold = 90 # 预算使用超过90%触发警报\n    }\n    \n    # 报告配置\n    Reporting = @{\n        GenerateDailyReport = $true\n        GenerateWeeklySummary = $true\n        GenerateMonthlyAnalysis = $true\n        OutputFormats = @(\"CSV\", \"JSON\", \"HTML\")\n        EmailNotification = $true\n        FeishuNotification = $true\n    }\n    \n    # 存储配置\n    Storage = @{\n        DataRetentionDays = 90\n        ReportRetentionDays = 365\n        BackupEnabled = $true\n    }\n}\n\n# 日志配置\n$LogFile = \"C:\\Users\\hytyw\\.openclaw\\workspace-finops\\logs\\cost_monitoring_$(Get-Date -Format 'yyyyMMdd').log\"\nfunction Write-Log {\n    param([string]$Message, [string]$Level = \"INFO\")\n    $Timestamp = Get-Date -Format \"yyyy-MM-dd HH:mm:ss\"\n    $LogMessage = \"$Timestamp [$Level] $Message\"\n    Add-Content -Path $LogFile -Value $LogMessage\n    if ($Level -eq \"ERROR\") { Write-Host $LogMessage -ForegroundColor Red }\n    elseif ($Level -eq \"WARNING\") { Write-Host $LogMessage -ForegroundColor Yellow }\n    else { Write-Host $LogMessage -ForegroundColor Green }\n}\n\n# 主函数\nfunction Start-CostMonitoring {\n    param(\n        [string]$Period = \"Daily\",\n        [switch]$ForceRefresh = $false\n    )\n    \n    Write-Log \"开始成本监控流程 - 周期: $Period\"\n    \n    try {\n        # 1. 收集成本数据\n        $CostData = Collect-CostData -Period $Period -ForceRefresh $ForceRefresh\n        \n        # 2. 分析成本数据\n        $AnalysisResults = Analyze-CostData -CostData $CostData -Period $Period\n        \n        # 3. 检测异常\n        $Anomalies = Detect-CostAnomalies -CostData $CostData -AnalysisResults $AnalysisResults\n        \n        # 4. 生成优化建议\n        $OptimizationSuggestions = Generate-OptimizationSuggestions -CostData $CostData -AnalysisResults $AnalysisResults\n        \n        # 5. 生成报告\n        $Report = Generate-CostReport -CostData $CostData -AnalysisResults $AnalysisResults -Anomalies $Anomalies -OptimizationSuggestions $OptimizationSuggestions -Period $Period\n        \n        # 6. 发送通知\n        Send-Notifications -Report $Report -Anomalies $Anomalies -Period $Period\n        \n        Write-Log \"成本监控流程完成\"\n        return $Report\n        \n    } catch {\n        Write-Log \"成本监控流程失败: $_\" -Level \"ERROR\"\n        throw\n    }\n}\n\n# 成本数据收集函数\nfunction Collect-CostData {\n    param(\n        [string]$Period,\n        [switch]$ForceRefresh\n    )\n    \n    Write-Log \"开始收集成本数据\"\n    \n    $CostData = @{\n        Timestamp = Get-Date\n        Period = $Period\n        DataSources = @()\n        RawData = @{}\n        Summary = @{}\n    }\n    \n    # 模拟从不同数据源收集数据\n    # 实际实现中，这里会调用云提供商的API\n    \n    # 模拟Azure成本数据\n    if ($Config.DataSources.CloudProvider -eq \"Azure\") {\n        $AzureData = @{\n            TotalCost = 12500.75\n            CostByService = @{\n                \"Virtual Machines\" = 4500.25\n                \"Storage\" = 1800.50\n                \"Networking\" = 1200.75\n                \"Databases\" = 3200.30\n                \"Other\" = 1799.95\n            }\n            CostByResourceGroup = @{\n                \"Production\" = 8500.25\n                \"Development\" = 2500.50\n                \"Testing\" = 1500.00\n            }\n            UsageMetrics = @{\n                \"CPU Hours\" = 8760\n                \"Storage GB\" = 5120\n                \"Network GB\" = 1024\n            }\n        }\n        $CostData.RawData.Azure = $AzureData\n        $CostData.DataSources += \"Azure\"\n    }\n    \n    # 模拟本地基础设施成本\n    $OnPremData = @{\n        TotalCost = 8500.00\n        CostByCategory = @{\n            \"Hardware\" = 3500.00\n            \"Software\" = 2500.00\n            \"Maintenance\" = 1500.00\n            \"Energy\" = 1000.00\n        }\n    }\n        $CostData.RawData.OnPrem = $OnPremData\n    $CostData.DataSources += \"OnPrem\"\n    \n    # 计算汇总数据\n    $CostData.Summary.TotalCost = $CostData.RawData.Azure.TotalCost + $CostData.RawData.OnPrem.TotalCost\n    $CostData.Summary.CostBreakdown = @{\n        \"Cloud\" = $CostData.RawData.Azure.TotalCost\n        \"OnPremises\" = $CostData.RawData.OnPrem.TotalCost\n    }\n    \n    Write-Log \"成本数据收集完成 - 总成本: $($CostData.Summary.TotalCost)\"\n    return $CostData\n}\n\n# 成本数据分析函数\nfunction Analyze-CostData {\n    param(\n        [object]$CostData,\n        [string]$Period\n    )\n    \n    Write-Log \"开始分析成本数据\"\n    \n    $Analysis = @{\n        Timestamp = Get-Date\n        Period = $Period\n        Trends = @{}\n        Comparisons = @{}\n        EfficiencyMetrics = @{}\n    }\n    \n    # 计算趋势（模拟数据）\n    $Analysis.Trends.DailyChange = 2.5  # 百分比\n    $Analysis.Trends.WeeklyChange = 8.3  # 百分比\n    $Analysis.Trends.MonthlyChange = 15.7  # 百分比\n    \n    # 计算比较数据\n    $Analysis.Comparisons.BudgetVsActual = @{\n        Budget = 20000.00\n        Actual = $CostData.Summary.TotalCost\n        Variance = $CostData.Summary.TotalCost - 20000.00\n        VariancePercentage = (($CostData.Summary.TotalCost - 20000.00) / 20000.00) * 100\n    }\n    \n    # 计算效率指标\n    $Analysis.EfficiencyMetrics.CostPerTransaction = 0.85\n    $Analysis.EfficiencyMetrics.ResourceUtilization = 68.5  # 百分比\n    $Analysis.EfficiencyMetrics.WasteIdentification = @{\n        \"IdleResources\" = 1200.00\n        \"Overprovisioned\" = 850.00\n        \"UnusedServices\" = 450.00\n    }\n    \n    Write-Log \"成本数据分析完成\"\n    return $Analysis\n}\n\n# 异常检测函数\nfunction Detect-CostAnomalies {\n    param(\n        [object]$CostData,\n        [object]$AnalysisResults\n    )\n    \n    Write-Log \"开始检测成本异常\"\n    \n    $Anomalies = @()\n    \n    # 检测预算超支\n    if ($AnalysisResults.Comparisons.BudgetVsActual.VariancePercentage -gt 10) {\n        $Anomalies += @{\n            Type = \"BudgetExceeded\"\n            Severity = \"High\"\n            Description = \"实际成本超过预算10%以上\"\n            Details = @{\n                Budget = $AnalysisResults.Comparisons.BudgetVsActual.Budget\n                Actual = $AnalysisResults.Comparisons.BudgetVsActual.Actual\n                Variance = $AnalysisResults.Comparisons.BudgetVsActual.Variance\n                VariancePercentage = $AnalysisResults.Comparisons.BudgetVsActual.VariancePercentage\n            }\n            Recommendation = \"审查成本驱动因素，考虑成本控制措施\"\n        }\n    }\n    \n    # 检测异常增长\n    if ($AnalysisResults.Trends.DailyChange -gt 5) {\n        $Anomalies += @{\n            Type = \"UnusualGrowth\"\n            Severity = \"Medium\"\n            Description = \"日成本增长超过5%\"\n            Details = @{\n                DailyChange = $AnalysisResults.Trends.DailyChange\n                Threshold = 5\n            }\n            Recommendation = \"调查具体服务或资源的使用情况\"\n        }\n    }\n    \n    # 检测资源浪费\n    $TotalWaste = $AnalysisResults.EfficiencyMetrics.WasteIdentification.IdleResources + \n                  $AnalysisResults.EfficiencyMetrics.WasteIdentification.Overprovisioned + \n                  $AnalysisResults.EfficiencyMetrics.WasteIdentification.UnusedServices\n    \n    if ($TotalWaste -gt 1000) {\n        $Anomalies += @{\n            Type = \"ResourceWaste\"\n            Severity = \"Medium\"\n            Description = \"识别到显著的资源浪费\"\n            Details = @{\n                TotalWaste = $TotalWaste\n                WasteBreakdown = $AnalysisResults.EfficiencyMetrics.WasteIdentification\n            }\n            Recommendation = \"优化资源配置，停用未使用服务\"\n        }\n    }\n    \n    Write-Log \"异常检测完成 - 发现 $($Anomalies.Count) 个异常\"\n    return $Anomalies\n}\n\n# 优化建议生成函数\nfunction Generate-OptimizationSuggestions {\n    param(\n        [object]$CostData,\n        [object]$AnalysisResults\n    )\n    \n    Write-Log \"开始生成优化建议\"\n    \n    $Suggestions = @()\n    \n    # 基于成本构成生成建议\n    $AzureCosts = $CostData.RawData.Azure.CostByService\n    $LargestService = ($AzureCosts.GetEnumerator() | Sort-Object Value -Descending | Select-Object -First 1)\n    \n    if ($LargestService.Value -gt 3000) {\n        $Suggestions += @{\n            Category = \"CostReduction\"\n            Priority = \"High\"\n            Title = \"优化 $($LargestService.Key) 成本\"\n            Description = \"$($LargestService.Key) 是最大的成本驱动因素，占总成本的 $(($LargestService.Value / $CostData.Summary.TotalCost * 100).ToString('F1'))%\"\n            EstimatedSavings = ($LargestService.Value * 0.15)  # 假设可以节约15%\n            ImplementationEffort = \"Medium\"\n            Timeline = \"2-4 weeks\"\n            Steps = @(\n                \"分析使用模式\",\n                \"调整资源配置\",\n                \"实施自动缩放\",\n                \"监控优化效果\"\n            )\n        }\n    }\n    \n    # 基于资源利用率生成建议\n    if ($AnalysisResults.EfficiencyMetrics.ResourceUtilization -lt 70) {\n        $Suggestions += @{\n            Category = \"EfficiencyImprovement\"\n            Priority = \"Medium\"\n            Title = \"提高资源利用率\"\n            Description = \"当前资源利用率为 $($AnalysisResults.EfficiencyMetrics.ResourceUtilization)%，低于目标水平\"\n            EstimatedSavings = $AnalysisResults.EfficiencyMetrics.WasteIdentification.IdleResources * 0.8\n            ImplementationEffort = \"Low\"\n            Timeline = \"1-2 weeks\"\n            Steps = @(\n                \"识别闲置资源\",\n                \"重新分配或停用\",\n                \"实施使用监控\",\n                \"建立优化流程\"\n            )\n        }\n    }\n    \n    # 基于浪费识别生成建议\n    $TotalWaste = $AnalysisResults.EfficiencyMetrics.WasteIdentification.IdleResources + \n                  $AnalysisResults.EfficiencyMetrics.WasteIdentification.Overprovisioned + \n                  $AnalysisResults.EfficiencyMetrics.WasteIdentification.UnusedServices\n    \n    if ($TotalWaste -gt 500) {\n        $Suggestions += @{\n            Category = \"WasteReduction\"\n            Priority = \"High\"\n            Title = \"减少资源浪费\"\n            Description = \"识别到 $($TotalWaste.ToString('F2')) 的资源浪费\"\n            EstimatedSavings = $TotalWaste * 0.9  # 假设可以回收90%\n            ImplementationEffort = \"Medium\"\n            Timeline = \"3-4 weeks\"\n            Steps = @(\n                \"审查所有服务\",\n                \"识别未使用资源\",\n                \"优化配置大小\",\n                \"实施定期审查\"\n            )\n        }\n    }\n    \n    Write-Log \"优化建议生成完成 - 生成 $($Suggestions.Count) 个建议\"\n    return $Suggestions\n}\n\n# 报告生成函数\nfunction Generate-CostReport {\n    param(\n        [object]$CostData,\n        [object]$AnalysisResults,\n        [array]$Anomalies,\n        [array]$OptimizationSuggestions,\n        [string]$Period\n    )\n    \n    Write-Log \"开始生成成本报告\"\n    \n    $Report = @{\n        Metadata = @{\n            GeneratedAt = Get-Date\n            Period = $Period\n            DataSources = $CostData.DataSources\n        }\n        ExecutiveSummary = @{\n            TotalCost = $CostData.Summary.TotalCost\n            BudgetStatus = $AnalysisResults.Comparisons.BudgetVsActual\n            KeyFindings = @()\n            Recommendations = @()\n        }\n        DetailedAnalysis = @{\n            CostBreakdown = $CostData.Summary.CostBreakdown\n            Trends = $AnalysisResults.Trends\n            EfficiencyMetrics = $AnalysisResults.EfficiencyMetrics\n        }\n        Anomalies = $Anomalies\n        OptimizationOpportunities = $OptimizationSuggestions\n        ActionItems = @()\n    }\n    \n    # 生成关键发现\n    if ($Anomalies.Count -gt 0) {\n        $Report.ExecutiveSummary.KeyFindings += \"发现 $($Anomalies.Count) 个成本异常需要关注\"\n    }\n    \n    if ($AnalysisResults.Comparisons.BudgetVsActual.VariancePercentage -gt 0) {\n        $Report.ExecutiveSummary.KeyFindings += \"实际成本超过预算 $($AnalysisResults.Comparisons.BudgetVsActual.VariancePercentage.ToString('F1'))%\"\n    }\n    \n    # 生成主要建议\n    $HighPrioritySuggestions = $OptimizationSuggestions | Where-Object { $_.Priority -eq \"High\" }\n    foreach ($Suggestion in $HighPrioritySuggestions) {\n        $Report.ExecutiveSummary.Recommendations += \"$($Suggestion.Title) - 预计节约: $($Suggestion.EstimatedSavings.ToString('F2'))\"\n    }\n    \n    # 生成行动项\n    if ($Anomalies.Count -gt 0) {\n        $Report.ActionItems += @{\n            Title = \"处理成本异常\"\n            Description = \"审查并处理检测到的成本异常\"\n            Owner = \"FinOps Team\"\n            DueDate = (Get-Date).AddDays(3).ToString(\"yyyy-MM-dd\")\n            Priority = \"High\"\n        }\n    }\n    \n    if ($OptimizationSuggestions.Count -gt 0) {\n        $Report.ActionItems += @{\n            Title = \"实施优化建议\"\n            Description = \"开始实施高优先级的优化建议\"\n            Owner = \"Infrastructure Team\"\n            DueDate = (Get-Date).AddDays(7).ToString(\"yyyy-MM-dd\")\n            Priority = \"Medium\"\n        }\n    }\n    \n    # 保存报告到文件\n    $ReportPath = \"C:\\Users\\hytyw\\.openclaw\\workspace-finops\\reports\\cost_report_$(Get-Date -Format 'yyyyMMdd_HHmmss').json\"\n    $Report | ConvertTo-Json -Depth 10 | Out-File -FilePath $ReportPath -Encoding UTF8\n    \n    Write-Log \"成本报告生成完成 - 保存到: $ReportPath\"\n    return $Report\n}\n\n# 通知发送函数\nfunction Send-Notifications {\n    param(\n        [object]$Report,\n        [array]$Anomalies,\n        [string]$Period\n    )\n    \n    Write-Log \"开始发送通知\"\n    \n    # 检查是否需要发送警报\n    $SendAlert = $false\n    $AlertMessage = \"FinOps成本监控报告 - $Period`n`n\"\n    \n    if ($Anomalies.Count -gt 0) {\n        $SendAlert = $true\n        $AlertMessage += \"⚠️ **发现 $($Anomalies.Count) 个成本异常**`n\"\n        foreach ($Anomaly in $Anomalies) {\n            $AlertMessage += \"- $($Anomaly.Description) (严重性: $($Anomaly.Severity))`n\"\n        }\n        $AlertMessage += \"`n\"\n    }\n    \n    # 添加摘要信息\n    $AlertMessage += \"📊 **成本摘要**`n\"\n    $AlertMessage += \"- 总成本: $($Report.ExecutiveSummary.TotalCost.ToString('F2'))`n\"\n    $AlertMessage += \"- 预算差异: $($Report.ExecutiveSummary.BudgetStatus.VariancePercentage.ToString('F1'))%`n\"\n    $AlertMessage += \"- 资源利用率: $($Report.DetailedAnalysis.EfficiencyMetrics.ResourceUtilization.ToString('F1'))%`n\"\n    \n    # 添加优化机会\n    $HighPrioritySuggestions = $Report.OptimizationOpportunities | Where-Object { $_.Priority -eq \"High\" }\n    if ($HighPrioritySuggestions.Count -gt 0) {\n        $AlertMessage += \"`n💡 **高优先级优化机会**`n\"\n        $TotalSavings = 0\n        foreach ($Suggestion in $HighPrioritySuggestions) {\n            $AlertMessage += \"- $($Suggestion.Title): 预计节约 $($Suggestion.EstimatedSavings.ToString('F2'))`n\"\n            $TotalSavings += $Suggestion.EstimatedSavings\n        }\n        $AlertMessage += \"总计节约潜力: $($TotalSavings.ToString('F2'))`n\"\n    }\n    \n    # 发送飞书通知（如果配置启用）\n    if ($Config.Reporting.FeishuNotification) {\n        try {\n            Send-Fe"}}],"api":"openai-completions","provider":"cherry-deepseek","model":"deepseek-chat","usage":{"input":136,"output":4096,"cacheRead":63936,"cacheWrite":0,"totalTokens":68168,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1776173358926}}
